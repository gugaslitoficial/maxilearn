generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  PROFESSOR
  STUDENT
}

enum CourseLevel {
  BASIC
  INTERMEDIATE
  ADVANCED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  REVOKED
}

enum QuizStatus {
  DRAFT
  PUBLISHED
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Company {
  id                 String   @id @default(cuid())
  name               String
  cnpj               String?
  segment            String?
  contactEmail       String?
  phone              String?
  site               String?
  platformName       String   @default("MaxiLearn")
  logoUrl            String?
  primaryColor       String   @default("#CC1F1F")
  secondaryColor     String   @default("#2A6FDB")
  faviconUrl         String?
  loginBackgroundUrl String?
  notifNewUser       Boolean  @default(true)
  notifCourseDone    Boolean  @default(true)
  notifInactiveAlert Boolean  @default(false)
  secTwoFactor       Boolean  @default(false)
  secStrongPassword  Boolean  @default(true)
  secSessionHours    Int      @default(8)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users           User[]
  courses         Course[]
  quizzes         Quiz[]
  certificates    Certificate[]
  notifications   Notification[]
  courseQuestions CourseQuestion[]
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role
  companyId    String
  avatarUrl    String?
  jobTitle     String?
  bio          String?
  isActive     Boolean   @default(true)
  lastAccessAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company             Company               @relation(fields: [companyId], references: [id])
  courses             Course[]              @relation("TeacherCourses")
  enrollments         Enrollment[]
  progress            LessonProgress[]
  quizSubmissions     QuizSubmission[]
  certificates        Certificate[]
  notifications       Notification[]
  courseQuestions     CourseQuestion[]      @relation("QuestionAuthor")
  questionReplies     CourseQuestionReply[] @relation("ReplyAuthor")

  @@index([companyId])
}

model Course {
  id                       String       @id @default(cuid())
  title                    String
  description              String?
  category                 String?
  level                    CourseLevel  @default(BASIC)
  thumbnailUrl             String?
  status                   CourseStatus @default(DRAFT)
  companyId                String
  teacherId                String
  allowDownload            Boolean      @default(false)
  issueCertificate         Boolean      @default(false)
  certificateType          String       @default("completion")
  minPassingScore          Int          @default(70)
  minApprovalScore         Int          @default(70)
  estimatedDurationMinutes Int?
  objectives               Json         @default("[]")
  isRestricted             Boolean      @default(false)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  company         Company          @relation(fields: [companyId], references: [id])
  teacher         User             @relation("TeacherCourses", fields: [teacherId], references: [id])
  modules         Module[]
  enrollments     Enrollment[]
  quizzes         Quiz[]
  certificates    Certificate[]
  courseQuestions CourseQuestion[]

  @@index([companyId])
  @@index([teacherId])
}

model Module {
  id       String @id @default(cuid())
  title    String
  order    Int
  courseId String

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
}

model Lesson {
  id              String   @id @default(cuid())
  title           String
  description     String?
  type            String   @default("video")
  videoUrl        String?
  durationMinutes Int?
  order           Int
  isFree          Boolean  @default(false)
  materials       Json     @default("[]")
  moduleId        String
  quizId          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  module          Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress        LessonProgress[]
  quiz            Quiz?            @relation("LessonQuiz", fields: [quizId], references: [id], onDelete: SetNull)
  courseQuestions CourseQuestion[]

  @@index([moduleId])
  @@index([quizId])
}

model Enrollment {
  id          String           @id @default(cuid())
  studentId   String
  courseId    String
  status      EnrollmentStatus @default(PENDING)
  requestedAt DateTime         @default(now())
  approvedAt  DateTime?

  student User   @relation(fields: [studentId], references: [id])
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([studentId])
  @@index([courseId])
}

model LessonProgress {
  id          String    @id @default(cuid())
  studentId   String
  lessonId    String
  completed   Boolean   @default(false)
  completedAt DateTime?

  student User   @relation(fields: [studentId], references: [id])
  lesson  Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
  @@index([studentId])
  @@index([lessonId])
}

model Quiz {
  id               String     @id @default(cuid())
  title            String
  courseId         String
  companyId        String
  minPassingScore  Int        @default(70)
  maxAttempts      Int?
  shuffleQuestions Boolean    @default(false)
  showAnswersAfter Boolean    @default(true)
  status           QuizStatus @default(DRAFT)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  company     Company          @relation(fields: [companyId], references: [id])
  lessons     Lesson[]         @relation("LessonQuiz")
  questions   Question[]
  submissions QuizSubmission[]

  @@index([courseId])
  @@index([companyId])
}

model Question {
  id           String       @id @default(cuid())
  quizId       String
  statement    String
  type         QuestionType
  order        Int
  options      Json
  displayCount Int?

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model QuizSubmission {
  id            String   @id @default(cuid())
  quizId        String
  studentId     String
  companyId     String
  answers       Json
  score         Int
  passed        Boolean
  attemptNumber Int
  submittedAt   DateTime @default(now())

  quiz    Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student User @relation(fields: [studentId], references: [id])

  @@index([quizId])
  @@index([studentId])
  @@index([companyId])
}

model Certificate {
  id             String   @id @default(cuid())
  studentId      String
  courseId       String
  companyId      String
  validationCode String   @unique @default(uuid())
  issuedAt       DateTime @default(now())
  studentName    String
  courseName     String
  teacherName    String
  courseDuration String?

  student User    @relation(fields: [studentId], references: [id])
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id])

  @@unique([studentId, courseId])
  @@index([studentId])
  @@index([courseId])
  @@index([companyId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  type      String
  title     String
  body      String?
  metadata  Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id])

  @@index([userId])
  @@index([companyId])
}

model CourseQuestion {
  id        String   @id @default(cuid())
  courseId  String
  lessonId  String
  authorId  String
  companyId String
  question  String
  createdAt DateTime @default(now())

  course   Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson   Lesson                @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  author   User                  @relation("QuestionAuthor", fields: [authorId], references: [id])
  company  Company               @relation(fields: [companyId], references: [id])
  replies  CourseQuestionReply[]

  @@index([lessonId])
  @@index([authorId])
  @@index([companyId])
}

model CourseQuestionReply {
  id         String   @id @default(cuid())
  questionId String
  authorId   String
  body       String
  createdAt  DateTime @default(now())

  question CourseQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  author   User           @relation("ReplyAuthor", fields: [authorId], references: [id])

  @@index([questionId])
  @@index([authorId])
}
